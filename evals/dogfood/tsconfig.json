{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "scorers/**/*.ts",
    "scorers/**/*.mjs",
    "scorers/**/*.d.ts",
    "runner/**/*.mjs",
    "vitest.config.ts",
    "vitest.acceptance.config.ts"
  ],
  "exclude": ["scorers/**/*.test.ts", "runner/**/*.test.ts"]
}

{
  "name": "template-engine-monorepo",
  "private": true,
  "description": "Monorepo for the secure templating engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betsalel-williamson/Templating-Engine.git"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run build && pnpm run test",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "release:tag": "node scripts/release-tag.mjs",
    "release:tag:push": "node scripts/release-tag.mjs --push",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  },
  "lint-staged": {
    "packages/**/*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,yml,yaml}": [
      "prettier --write"
    ],
    "eslint.config.mjs": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.9.1",
    "typescript-eslint": "^8.62.0"
  }
}

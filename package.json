{
  "name": "template-engine-monorepo",
  "private": true,
  "description": "Monorepo for the secure templating engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betsalel-williamson/Templating-Engine.git"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "docs:compile": "mdcp compile --config docs/mdcp.config.json --docs-root docs --warn-broken-links",
    "docs:check": "mdcp check --config docs/mdcp.config.json --docs-root docs --require-lint --skip-vale",
    "docs:context": "cat docs/_build/features.md",
    "docs:refs": "mdcp refs-list --config docs/mdcp.config.json --docs-root docs",
    "dogfood:test": "pnpm --filter @bwilliamson/dogfood-evals test",
    "dogfood:run": "node evals/dogfood/runner/run-pair.mjs",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run build && pnpm run test",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "release:tag": "node scripts/release-tag.mjs",
    "release:tag:push": "node scripts/release-tag.mjs --push",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "typescript": "^6.0.3"
    }
  },
  "lint-staged": {
    "packages/**/*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "evals/**/*.{ts,mjs,js}": [
      "prettier --write"
    ],
    "**/*.{json,jsonc,md,yml,yaml}": [
      "prettier --write"
    ],
    "eslint.config.mjs": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@bwilliamson/mdcp-cli": "0.6.1",
    "@bwilliamson/mdcp-presets": "0.6.1",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}

{
  "name": "@bwilliamson/template-engine-cli",
  "version": "0.0.4",
  "description": "CLI for the secure templating engine",
  "license": "MIT",
  "type": "module",
  "bin": {
    "template-engine": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betsalel-williamson/Templating-Engine.git",
    "directory": "packages/template-engine-cli"
  },
  "bugs": {
    "url": "https://github.com/betsalel-williamson/Templating-Engine/issues"
  },
  "homepage": "https://github.com/betsalel-williamson/Templating-Engine/tree/main/packages/template-engine-cli#readme",
  "keywords": [
    "template",
    "engine",
    "cli"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "build:sea-bundle": "esbuild src/cli.ts --bundle --platform=node --outfile=dist/cli.bundle.cjs --format=cjs --packages=bundle",
    "sea:blob": "node --experimental-sea-config sea-config.json",
    "build:standalone:linux": "pnpm --filter @bwilliamson/template-engine-core run build && pnpm run build:sea-bundle && pnpm run sea:blob && ./scripts/build-sea-linux.sh",
    "build:standalone:macos": "pnpm --filter @bwilliamson/template-engine-core run build && pnpm run build:sea-bundle && pnpm run sea:blob && ./scripts/build-sea-macos.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@bwilliamson/template-engine-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.25.5",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.4.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}

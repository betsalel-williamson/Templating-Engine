{
  "name": "@bwilliamson/template-engine-core",
  "version": "0.0.3",
  "description": "Secure templating engine core library",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betsalel-williamson/Templating-Engine.git",
    "directory": "packages/template-engine-core"
  },
  "bugs": {
    "url": "https://github.com/betsalel-williamson/Templating-Engine/issues"
  },
  "homepage": "https://github.com/betsalel-williamson/Templating-Engine/tree/main/packages/template-engine-core#readme",
  "keywords": [
    "template",
    "engine",
    "codegen"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:parsers": "node scripts/ensure-lib-dir.mjs && peggy --format es src/grammar.peggy -o lib/parser.js && peggy --format es src/grammar_new.peggy -o lib/parser_new.js && node scripts/write-parser-dts.mjs",
    "build": "pnpm run build:parsers && tsup src/index.ts --format esm --dts --clean",
    "test": "pnpm run build:parsers && vitest run",
    "typecheck": "pnpm run build:parsers && tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "peggy": "^5.0.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

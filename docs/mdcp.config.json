{
  "protocol": {
    "profile": "alpha",
    "ref": "v0.4.1"
  },
  "outputDir": "_build",
  "outputFile": "guides.md",
  "compileOrder": ["features", "developer", "client"],
  "banner": "<!-- Generated by mdcp compile. Edit shards under docs/, not this file. -->\n\n",
  "guides": [
    { "name": "features", "compile": { "scopeRoot": "glossary" } },
    {
      "name": "developer",
      "compile": {
        "scopeRoot": "glossary",
        "outputFile": "../../DEVELOPERS.md",
        "includeBanner": false,
        "crossGuideLinks": { "ignoreGuides": ["features"] }
      }
    },
    {
      "name": "client",
      "compile": {
        "scopeRoot": "glossary",
        "outputFile": "_build/client.md",
        "crossGuideLinks": { "ignoreGuides": ["features"] }
      }
    }
  ],
  "refs": {
    "registryFile": ".caches/refs.json",
    "slugAlgorithm": "github"
  },
  "lint": {
    "markdownlint": {
      "shardsConfig": "../node_modules/@bwilliamson/mdcp-presets/markdownlint-shards.markdownlint-cli2.jsonc",
      "compiledConfig": "compiled-lint.markdownlint-cli2.jsonc",
      "shardsGlobs": ["glossary", "features", "developer", "client"]
    },
    "xrefs": { "enabled": true }
  },
  "export": {
    "llm": {
      "stripHtmlComments": true,
      "stripFrontmatter": true,
      "stripBanner": true,
      "collapseBlankLines": true
    }
  },
  "extensions": {
    "packs": [{ "id": "prompts-mdcp-defaults", "enabled": true, "version": "0.4.0.0" }]
  }
}
